<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pixel Racer X</title>
  <style>
    body {
      margin: 0;
      background: radial-gradient(circle at 50% 20%, #0b1220, #000);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      font-family: monospace;
      color: #e5e7eb;
      overflow: hidden;
    }

    canvas {
      image-rendering: pixelated;
      border: 6px solid #1f2937;
      box-shadow: 0 0 40px rgba(59,130,246,0.3);
      background: #0a0f1f;
      max-width: 100vw;
      height: auto;
    }

    #ui {
      position: absolute;
      top: 15px;
      left: 15px;
      font-size: 18px;
      color: #93c5fd;
      z-index: 2;
    }

    #menu {
      position: absolute;
      text-align: center;
      color: white;
      z-index: 2;
    }

    button {
      background: #3b82f6;
      border: none;
      padding: 10px 20px;
      margin-top: 15px;
      cursor: pointer;
      color: white;
      font-weight: bold;
      border-radius: 6px;
    }

    button:hover {
      background: #2563eb;
    }

    /* Mobile controls */
    #controls {
      position: absolute;
      bottom: 20px;
      display: flex;
      gap: 20px;
      z-index: 2;
    }

    .ctrl {
      width: 80px;
      height: 80px;
      background: rgba(59,130,246,0.2);
      border: 2px solid #3b82f6;
      color: white;
      font-size: 30px;
      border-radius: 12px;
      display: flex;
      justify-content: center;
      align-items: center;
      user-select: none;
      touch-action: manipulation;
    }

    .ctrl:active {
      background: rgba(59,130,246,0.5);
    }
  </style>
</head>
<body>

<div id="ui">Score: 0</div>

<div id="menu">
  <h1>PIXEL RACER X</h1>
  <p>Tryk START for at spille</p>
  <button onclick="startGame()">START</button>
</div>

<canvas id="game" width="400" height="600"></canvas>

<div id="controls">
  <div class="ctrl" id="left">⬅</div>
  <div class="ctrl" id="right">➡</div>
</div>

<script>
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');

let player, obstacles, keys, score, speed, running;

function resetGame() {
  player = { x: 180, y: 500, w: 30, h: 50 };
  obstacles = [];
  keys = {};
  score = 0;
  speed = 2.5;
  running = true;
}

function startGame() {
  document.getElementById('menu').style.display = 'none';
  resetGame();
  gameLoop();
}

// keyboard
window.addEventListener('keydown', e => keys[e.key] = true);
window.addEventListener('keyup', e => keys[e.key] = false);

// mobile controls
const leftBtn = document.getElementById('left');
const rightBtn = document.getElementById('right');

leftBtn.addEventListener('touchstart', () => keys['ArrowLeft'] = true);
leftBtn.addEventListener('touchend', () => keys['ArrowLeft'] = false);

rightBtn.addEventListener('touchstart', () => keys['ArrowRight'] = true);
rightBtn.addEventListener('touchend', () => keys['ArrowRight'] = false);

function spawnObstacle() {
  let x = Math.floor(Math.random() * 8) * 50;
  obstacles.push({ x: x, y: -60, w: 30, h: 50 });
}

setInterval(() => {
  if (running) spawnObstacle();
}, 900);

function update() {
  if (!running) return;

  if (keys['ArrowLeft']) player.x -= 5;
  if (keys['ArrowRight']) player.x += 5;

  player.x = Math.max(0, Math.min(canvas.width - player.w, player.x));

  speed += 0.0012;

  obstacles.forEach(o => {
    o.y += speed;

    if (
      player.x < o.x + o.w &&
      player.x + player.w > o.x &&
      player.y < o.y + o.h &&
      player.y + player.h > o.y
    ) {
      running = false;
      setTimeout(() => {
        alert('Game Over! Score: ' + score);
        document.location.reload();
      }, 100);
    }
  });

  obstacles = obstacles.filter(o => o.y < canvas.height);

  score++;
  document.getElementById('ui').innerText = 'Score: ' + score;
}

function drawCar(x, y, color) {
  ctx.fillStyle = color;
  ctx.fillRect(x, y, 30, 50);

  ctx.fillStyle = '#111';
  ctx.fillRect(x + 5, y + 5, 20, 15);

  ctx.fillStyle = '#60a5fa';
  ctx.fillRect(x + 5, y + 25, 20, 15);
}

function draw() {
  ctx.fillStyle = '#020617';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  ctx.fillStyle = 'rgba(59,130,246,0.1)';
  ctx.fillRect(100, 0, 200, canvas.height);

  ctx.fillStyle = '#e5e7eb';
  for (let i = 0; i < 600; i += 40) {
    ctx.fillRect(195, i + (score % 40), 10, 20);
  }

  drawCar(player.x, player.y, '#22d3ee');
  obstacles.forEach(o => drawCar(o.x, o.y, '#ef4444'));
}

function gameLoop() {
  update();
  draw();
  if (running) requestAnimationFrame(gameLoop);
}
</script>

</body>
</html>
